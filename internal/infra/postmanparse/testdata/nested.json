{
  "info": {
    "name": "Nested Testdata",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.example.com/users"
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "https://api.example.com/users"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John\", \"email\": \"john@example.com\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    }
  ]
}
